+  }
+
+ private:
+  TabRenameCallback callback_;
+};
+
+}  // namespace
+
+void ShowTabRenameDialog(content::WebContents* web_contents,
+                         std::u16string initial_title,
+                         TabRenameCallback callback) {
+  if (!web_contents) {
+    return;
+  }
+
+  auto delegate = std::make_unique<TabRenameDialogDelegate>(std::move(callback));
+  auto* delegate_ptr = delegate.get();
+  auto dialog_model =
+      ui::DialogModel::Builder(std::move(delegate))
+          .SetTitle(l10n_util::GetStringUTF16(IDS_TAB_CXMENU_RENAMETAB))
+          .AddTextfield(
+              kTabNameTextfield,
+              l10n_util::GetStringUTF16(IDS_TAB_RENAME_DIALOG_PLACEHOLDER),
+              std::move(initial_title))
+          .AddOkButton(base::BindOnce(&TabRenameDialogDelegate::OnAccepted,
+                                      base::Unretained(delegate_ptr)))
+          .AddCancelButton(base::DoNothing())
+          .Build();
+  auto dialog = views::BubbleDialogModelHost::CreateModal(
+      std::move(dialog_model), ui::mojom::ModalType::kChild);
+  constrained_window::ShowWebModalDialogViews(dialog.release(), web_contents);
+}
