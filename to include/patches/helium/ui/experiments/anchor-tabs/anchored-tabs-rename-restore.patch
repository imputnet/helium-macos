+
+void TabUIHelper::MaybeFetchRestoredFavicon(content::NavigationEntry* entry) {
+  if (!entry || favicon_fetch_in_flight_) {
+    return;
+  }
+
+  const GURL page_url = entry->GetURL();
+  if (!page_url.is_valid() || last_requested_favicon_page_url_ == page_url) {
+    return;
+  }
+
+  Profile* const profile =
+      Profile::FromBrowserContext(web_contents()->GetBrowserContext());
+  favicon::FaviconService* const favicon_service =
+      profile ? FaviconServiceFactory::GetForProfile(
+                    profile, ServiceAccessType::EXPLICIT_ACCESS)
+              : nullptr;
+  if (!favicon_service) {
+    return;
+  }
+
+  favicon_fetch_in_flight_ = true;
+  last_requested_favicon_page_url_ = page_url;
+  favicon::GetFaviconImageForPageURL(
+      favicon_service, page_url, favicon_base::IconType::kFavicon,
+      base::BindOnce(&TabUIHelper::OnRestoredFaviconFetched,
+                     weak_factory_.GetWeakPtr(), page_url),
+      &favicon_task_tracker_);
+}
+
+void TabUIHelper::OnRestoredFaviconFetched(
+    const GURL& page_url,
+    const favicon_base::FaviconImageResult& result) {
+  favicon_fetch_in_flight_ = false;
+  if (!web_contents()) {
+    return;
+  }
+
+  content::NavigationEntry* const entry =
+      web_contents()->GetController().GetLastCommittedEntry();
+  if (!entry || entry->GetURL() != page_url || result.image.IsEmpty()) {
+    if (entry && entry->GetURL() == page_url && result.image.IsEmpty()) {
+      last_requested_favicon_page_url_ = GURL();
+    }
+    return;
+  }
+
+  content::FaviconStatus& favicon_status = entry->GetFavicon();
+  favicon_status.valid = true;
+  if (result.icon_url.is_valid()) {
+    favicon_status.url = result.icon_url;
+  }
+  favicon_status.image = result.image;
+  web_contents()->NotifyNavigationStateChanged(content::INVALIDATE_TYPE_TAB);
+  tab_ui_change_callbacks_.Notify();
+}
+
+void TabUIHelper::SetCustomTitle(std::u16string title, bool persist) {
+  custom_title_ = std::move(title);
+  // Push the new title through the existing tab-state-changed plumbing.
+  if (web_contents()) {
+    web_contents()->NotifyNavigationStateChanged(
+        content::INVALIDATE_TYPE_TITLE);
+  }
+  tab_ui_change_callbacks_.Notify();
+
+  if (!persist || !web_contents()) {
+    return;
+  }
+
+  Profile* const profile =
+      Profile::FromBrowserContext(web_contents()->GetBrowserContext());
+  SessionService* const session_service =
+      profile ? SessionServiceFactory::GetForProfile(profile) : nullptr;
+  sessions::SessionTabHelper* const tab_helper =
+      sessions::SessionTabHelper::FromWebContents(web_contents());
+  if (!session_service || !tab_helper) {
+    return;
+  }
+
+  session_service->AddTabExtraData(
+      tab_helper->window_id(), tab_helper->session_id(), kCustomTitleSessionKey,
+      base::UTF16ToUTF8(custom_title_));
+}
+
+void TabUIHelper::RestoreCustomTitleFromExtraData(
+    content::WebContents* web_contents,
+    const std::map<std::string, std::string>& extra_data) {
+  if (!web_contents) {
+    return;
+  }
+
+  auto it = extra_data.find(kCustomTitleSessionKey);
+  if (it == extra_data.end() || it->second.empty()) {
+    return;
+  }
+
+  if (tabs::TabInterface* const tab_interface =
+          tabs::TabInterface::GetFromContents(web_contents)) {
+    if (TabUIHelper* const helper = TabUIHelper::From(tab_interface)) {
+      helper->SetCustomTitle(base::UTF8ToUTF16(it->second),
+                             /*persist=*/false);
+    }
+  }
+}
+
+base::WeakPtr<TabUIHelper> TabUIHelper::GetWeakPtr() {
+  return weak_factory_.GetWeakPtr();
+}
