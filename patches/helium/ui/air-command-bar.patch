+void TabSearchPageHandler::OpenNewTab(const std::string& query) {
+  auto embedder = webui_controller_->embedder();
+  if (embedder) {
+    embedder->CloseUI();
+  }
+  if (!browser_) return;
+
+  GURL url;
+  if (query.empty()) {
+    url = GURL(chrome::kChromeUINewTabURL);
+  } else {
+    // Detect URL-like input: has a scheme already, or looks like a bare domain
+    // (contains a dot, no spaces, length > 3).
+    bool has_scheme = query.find("://") != std::string::npos;
+    bool looks_like_domain = query.find(' ') == std::string::npos &&
+                             query.find('.') != std::string::npos &&
+                             query.size() > 3;
+    if (has_scheme) {
+      url = GURL(query);
+    } else if (looks_like_domain) {
+      url = GURL("https://" + query);
+    }
+    if (!url.is_valid() || url.host().empty()) {
+      url = GURL("https://www.google.com/search?q=" +
+                 base::EscapeQueryParamValue(query, /*use_plus=*/false));
+    }
+  }
+  NavigateParams params(browser_, url, ui::PAGE_TRANSITION_TYPED);
+  params.disposition = WindowOpenDisposition::NEW_FOREGROUND_TAB;
+  Navigate(&params);
+}
