+void EnsureDiscardStatus(content::WebContents* web_contents) {
+  auto* const usage =
+      performance_manager::user_tuning::UserPerformanceTuningManager::
+          PreDiscardResourceUsage::FromWebContents(web_contents);
+  if (usage) {
+    usage->UpdateDiscardInfo(base::ByteSize(0),
+                             mojom::LifecycleUnitDiscardReason::EXTERNAL);
+    return;
+  }
+
+  performance_manager::user_tuning::UserPerformanceTuningManager::
+      PreDiscardResourceUsage::CreateForWebContents(
+          web_contents, base::ByteSize(0),
+          mojom::LifecycleUnitDiscardReason::EXTERNAL);
+}
+
+bool StampWebContentsHibernatedForRestore(content::WebContents* web_contents,
+                                          bool mark_discarded) {
+  if (!features::IsHeliumAnchoredTabsEnabled() || !web_contents) {
+    return false;
+  }
+
+  Profile* const profile =
+      Profile::FromBrowserContext(web_contents->GetBrowserContext());
+  SessionService* const session_service =
+      profile ? SessionServiceFactory::GetForProfile(profile) : nullptr;
+  sessions::SessionTabHelper* const tab_helper =
+      sessions::SessionTabHelper::FromWebContents(web_contents);
+  if (session_service && tab_helper) {
+    session_service->AddTabExtraData(tab_helper->window_id(),
+                                     tab_helper->session_id(),
+                                     TabUIHelper::kHibernatedSessionKey, "1");
+  }
+
+  if (mark_discarded) {
+    web_contents->SetWasDiscarded(true);
+  }
+  EnsureDiscardStatus(web_contents);
+  return true;
+}
+
+std::optional<int> FindFallbackTabIndex(
+    TabStripModel* model,
+    int model_index,
+    std::optional<tab_groups::TabGroupId> target_group) {
+  CHECK(model);
+
+  auto is_live_tab_in_group = [&](int index,
+                                  tab_groups::TabGroupId group) {
+    return model->GetTabGroupForTab(index) == group &&
+           model->GetWebContentsAt(index) &&
+           !model->GetWebContentsAt(index)->WasDiscarded();
+  };
+  if (target_group.has_value()) {
+    for (int i = model_index + 1; i < model->count(); ++i) {
+      if (is_live_tab_in_group(i, *target_group)) {
+        return i;
+      }
+    }
+    for (int i = model_index - 1; i >= 0; --i) {
+      if (is_live_tab_in_group(i, *target_group)) {
+        return i;
+      }
+    }
+  }
+
+  for (int i = model_index + 1; i < model->count(); ++i) {
+    if ((!target_group.has_value() ||
+         model->GetTabGroupForTab(i) != target_group) &&
+        model->GetWebContentsAt(i) &&
+        !model->GetWebContentsAt(i)->WasDiscarded()) {
+      return i;
+    }
+  }
+  for (int i = model_index - 1; i >= 0; --i) {
+    if ((!target_group.has_value() ||
+         model->GetTabGroupForTab(i) != target_group) &&
+        model->GetWebContentsAt(i) &&
+        !model->GetWebContentsAt(i)->WasDiscarded()) {
+      return i;
+    }
+  }
+  if (model_index + 1 < model->count()) {
+    content::WebContents* const contents =
+        model->GetWebContentsAt(model_index + 1);
+    if (contents && !contents->WasDiscarded()) {
+      return model_index + 1;
+    }
+  }
+  if (model_index - 1 >= 0) {
+    content::WebContents* const contents =
+        model->GetWebContentsAt(model_index - 1);
+    if (contents && !contents->WasDiscarded()) {
+      return model_index - 1;
+    }
+  }
+
+  return std::nullopt;
+}
+
+bool ActivateFallbackTab(TabStripModel* model,
+                         int model_index,
+                         std::optional<tab_groups::TabGroupId> target_group) {
+  const std::optional<int> fallback_index =
+      FindFallbackTabIndex(model, model_index, target_group);
+  if (!fallback_index.has_value()) {
+    model->delegate()->AddTabAt(GURL(), -1, true);
+    return model->active_index() != model_index;
+  }
+
+  model->ActivateTabAt(fallback_index.value(),
+                       TabStripUserGestureDetails(
+                           TabStripUserGestureDetails::GestureType::kOther));
+  return model->active_index() != model_index;
+}
+
+bool HibernateWebContents(content::WebContents* web_contents) {
+  if (!web_contents || web_contents->WasDiscarded()) {
+    return false;
+  }
+
+  GURL anchored_url;
+  std::u16string anchored_title;
+  if (tabs::TabInterface* const tab =
+          tabs::TabInterface::GetFromContents(web_contents)) {
+    if (TabUIHelper* const helper = TabUIHelper::From(tab)) {
+      anchored_url = helper->anchored_url();
+      anchored_title = helper->anchored_title();
+    }
+  }
+
+  StampWebContentsHibernatedForRestore(web_contents, false);
+
+  content::WebContents* const discarded_contents =
+      g_browser_process->GetTabManager()->DiscardTabByExtension(web_contents);
+  if (!discarded_contents) {
+    return false;
+  }
+
+  if (anchored_url.is_valid()) {
+    content::NavigationEntry* const entry =
+        discarded_contents->GetController().GetLastCommittedEntry();
+    if (entry) {
+      entry->SetURL(anchored_url);
+      entry->SetVirtualURL(anchored_url);
+      if (!anchored_title.empty()) {
+        entry->SetTitle(anchored_title);
+      }
+    }
+    if (tabs::TabInterface* const tab =
+            tabs::TabInterface::GetFromContents(discarded_contents)) {
+      if (TabUIHelper* const helper = TabUIHelper::From(tab)) {
+        helper->SetAnchoredURL(anchored_url, std::move(anchored_title));
+      }
+    }
+  }
+
+  StampWebContentsHibernatedForRestore(discarded_contents, true);
+  return true;
+}
+
+std::optional<tab_groups::TabGroupId> GetTabGroupFromModel(
+    const tabs::TabInterface* tab) {
+  if (!tab || !tab->GetBrowserWindowInterface()) {
+    return std::nullopt;
+  }
+
+  const TabStripModel* const model =
+      tab->GetBrowserWindowInterface()->GetTabStripModel();
+  if (!model) {
+    return std::nullopt;
+  }
+
+  const std::optional<int> index = model->GetIndexOfTab(tab);
+  if (!index.has_value()) {
+    return std::nullopt;
+  }
+  return model->GetTabGroupForTab(index.value());
+}
+
+}  // namespace
+
+namespace helium {
+
+bool MarkWebContentsHibernatedForRestore(content::WebContents* web_contents) {
+  return StampWebContentsHibernatedForRestore(web_contents, true);
+}
+
+void AddAnchoredTabExtraData(content::WebContents* web_contents,
+                             std::map<std::string, std::string>* extra_data) {
+  if (!features::IsHeliumAnchoredTabsEnabled() || !web_contents ||
+      !extra_data) {
+    return;
+  }
+
+  if (tabs::TabInterface* const tab =
+          tabs::TabInterface::GetFromContents(web_contents)) {
+    if (TabUIHelper* const helper = TabUIHelper::From(tab)) {
+      if (!helper->custom_title().empty()) {
+        (*extra_data)[TabUIHelper::kCustomTitleSessionKey] =
+            base::UTF16ToUTF8(helper->custom_title());
+      }
+      if (helper->anchored_url().is_valid()) {
+        (*extra_data)[TabUIHelper::kAnchoredURLSessionKey] =
+            helper->anchored_url().spec();
+      }
+      if (!helper->anchored_title().empty()) {
+        (*extra_data)[TabUIHelper::kAnchoredTitleSessionKey] =
+            base::UTF16ToUTF8(helper->anchored_title());
+      }
+    }
+  }
+
+  if (web_contents->WasDiscarded()) {
+    (*extra_data)[TabUIHelper::kHibernatedSessionKey] = "1";
+  }
+}
+
+void RestoreAnchoredTabExtraData(
+    content::WebContents* web_contents,
+    const std::map<std::string, std::string>& extra_data) {
+  if (!features::IsHeliumAnchoredTabsEnabled() || !web_contents) {
+    return;
+  }
+
+  TabUIHelper::RestoreCustomTitleFromExtraData(web_contents, extra_data);
+  TabUIHelper::RestoreAnchoredURLFromExtraData(web_contents, extra_data);
+}
+
+bool ShouldRestoreHibernated(
+    const std::map<std::string, std::string>& extra_data) {
+  if (!features::IsHeliumAnchoredTabsEnabled()) {
+    return false;
+  }
+
+  auto it = extra_data.find(TabUIHelper::kHibernatedSessionKey);
+  return it != extra_data.end() && it->second == "1";
+}
+
+bool IsAnchoredTab(const TabStripModel* model, int model_index) {
+  return features::IsHeliumAnchoredTabsEnabled() && model &&
+         model->ContainsIndex(model_index) &&
+         (model->GetTabGroupForTab(model_index).has_value() ||
+          model->IsTabPinned(model_index));
+}
+
+bool IsLiveAnchoredTab(const TabStripModel* model, int model_index) {
+  return IsAnchoredTab(model, model_index) &&
+         model->GetWebContentsAt(model_index) &&
+         !model->GetWebContentsAt(model_index)->WasDiscarded();
+}
+
+bool MaybeHibernateAnchoredTab(TabStripModel* model, int model_index) {
+  if (!IsLiveAnchoredTab(model, model_index)) {
+    return false;
+  }
+
+  const std::optional<tab_groups::TabGroupId> group =
+      model->GetTabGroupForTab(model_index);
+  content::WebContents* const web_contents =
+      model->GetWebContentsAt(model_index);
+  if (model_index == model->active_index() &&
+      !ActivateFallbackTab(model, model_index, group)) {
+    return false;
+  }
+
+  return HibernateWebContents(web_contents);
+}
+
+bool MaybeHibernateGroupedTab(TabStripModel* model, int model_index) {
+  if (!features::IsHeliumAnchoredTabsEnabled()) {
+    return false;
+  }
+
+  if (!model || !model->ContainsIndex(model_index) || model->count() <= 1) {
+    return false;
+  }
+
+  const std::optional<tab_groups::TabGroupId> group =
+      model->GetTabGroupForTab(model_index);
+  if (!group.has_value()) {
+    return false;
+  }
+
+  if (model_index == model->active_index() &&
+      !ActivateFallbackTab(model, model_index, group)) {
+    return false;
+  }
+
+  return HibernateWebContents(model->GetWebContentsAt(model_index));
+}
+
+bool HibernateTabGroup(TabStripModel* model, tab_groups::TabGroupId group) {
+  if (!features::IsHeliumAnchoredTabsEnabled()) {
+    return false;
+  }
+
+  if (!model || !model->group_model()->ContainsTabGroup(group)) {
+    return false;
+  }
+
+  bool any_hibernated = false;
+  const gfx::Range tab_range =
+      model->group_model()->GetTabGroup(group)->ListTabs();
+  for (int model_index : tab_range.ToIntVector()) {
+    content::WebContents* const web_contents =
+        model->GetWebContentsAt(model_index);
+    any_hibernated |= HibernateWebContents(web_contents);
+  }
+
+  return any_hibernated;
+}
+
+bool ShouldShowGroupedTabHibernateAffordance(const tabs::TabInterface* tab,
+                                             bool is_tab_discarded) {
+  if (!features::IsHeliumAnchoredTabsEnabled() || !tab || is_tab_discarded) {
+    return false;
+  }
+
+  return GetTabGroupFromModel(tab).has_value();
+}
+
+bool ShouldShowCollapsedGroupHibernateAffordance(TabStripModel* model,
+                                                 tab_groups::TabGroupId group) {
+  if (!features::IsHeliumAnchoredTabsEnabled()) {
+    return false;
+  }
+
+  if (!model || !model->group_model()->ContainsTabGroup(group) ||
+      !model->IsGroupCollapsed(group)) {
+    return false;
+  }
+
+  const gfx::Range tab_range =
+      model->group_model()->GetTabGroup(group)->ListTabs();
+  for (int model_index : tab_range.ToIntVector()) {
+    content::WebContents* const web_contents =
+        model->GetWebContentsAt(model_index);
+    if (web_contents && !web_contents->WasDiscarded()) {
+      return true;
+    }
+  }
+
+  return false;
+}
+
+}  // namespace helium
