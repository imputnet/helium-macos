+void TabUIHelper::SetAnchoredURL(const GURL& url,
+                                 std::u16string title,
+                                 bool persist) {
+  if (!features::IsHeliumAnchoredTabsEnabled() || !url.is_valid()) {
+    return;
+  }
+
+  anchored_url_ = url;
+  anchored_title_ = std::move(title);
+  if (!persist || !web_contents()) {
+    return;
+  }
+
+  Profile* const profile =
+      Profile::FromBrowserContext(web_contents()->GetBrowserContext());
+  SessionService* const session_service =
+      profile ? SessionServiceFactory::GetForProfile(profile) : nullptr;
+  sessions::SessionTabHelper* const tab_helper =
+      sessions::SessionTabHelper::FromWebContents(web_contents());
+  if (!session_service || !tab_helper) {
+    return;
+  }
+
+  session_service->AddTabExtraData(
+      tab_helper->window_id(), tab_helper->session_id(), kAnchoredURLSessionKey,
+      anchored_url_.spec());
+  if (!anchored_title_.empty()) {
+    session_service->AddTabExtraData(
+        tab_helper->window_id(), tab_helper->session_id(),
+        kAnchoredTitleSessionKey, base::UTF16ToUTF8(anchored_title_));
+  }
+}
+
+void TabUIHelper::RestoreAnchoredURLFromExtraData(
+    content::WebContents* web_contents,
+    const std::map<std::string, std::string>& extra_data) {
+  if (!features::IsHeliumAnchoredTabsEnabled() || !web_contents) {
+    return;
+  }
+
+  auto it = extra_data.find(kAnchoredURLSessionKey);
+  if (it == extra_data.end()) {
+    return;
+  }
+
+  const GURL url(it->second);
+  if (!url.is_valid()) {
+    return;
+  }
+
+  std::u16string title;
+  if (auto title_it = extra_data.find(kAnchoredTitleSessionKey);
+      title_it != extra_data.end()) {
+    title = base::UTF8ToUTF16(title_it->second);
+  }
+
+  if (tabs::TabInterface* const tab_interface =
+          tabs::TabInterface::GetFromContents(web_contents)) {
+    if (TabUIHelper* const helper = TabUIHelper::From(tab_interface)) {
+      helper->SetAnchoredURL(url, std::move(title), /*persist=*/false);
+    }
+  }
+}
 
