+void BrowserView::ReloadAccelerators() {
+  views::FocusManager* focus_manager = GetFocusManager();
+  if (!focus_manager) {
+    return;
+  }
+  focus_manager->UnregisterAccelerators(this);
+  accelerator_table_.clear();
+  LoadAccelerators();
+  UpdatePlatformAccelerators();
+}
+
+void BrowserView::OnBrowserShortcutsChanged() {
+  ReloadAccelerators();
+}
+
+void BrowserView::UpdatePlatformAccelerators() {
+#if BUILDFLAG(IS_MAC)
+  if (!base::FeatureList::IsEnabled(features::kCustomizableBrowserShortcuts) ||
+      !browser_shortcut_service_ || !IsActive()) {
+    return;
+  }
+
+  browser_shortcuts::UpdatePlatformMenuAccelerators(
+      browser_shortcut_service_->GetAcceleratorMap());
+#endif
+}
