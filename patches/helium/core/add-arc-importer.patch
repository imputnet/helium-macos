+// macOS CFAbsoluteTime epoch: 2001-01-01 00:00:00 UTC
+// Unix epoch offset: 978307200 seconds between 1970-01-01 and 2001-01-01.
+constexpr double kCFAbsoluteTimeToUnixOffset = 978307200.0;
+
+base::Time CFAbsoluteTimeToBaseTime(double cf_time) {
+  return base::Time::FromSecondsSinceUnixEpoch(cf_time +
+                                               kCFAbsoluteTimeToUnixOffset);
+}
+
+// Represents a parsed sidebar item from StorableSidebar.json.
+struct ArcSidebarItem {
+  std::string id;
+  std::string title;
+  std::string saved_url;
+  std::string saved_title;
+  double created_at = 0;
+  std::vector<std::string> children_ids;
+  bool is_container = false;
+};
+
+// Parse the flat item list from the sidebar JSON into a map of id -> item.
+// The items array alternates between id strings and item objects:
+//   ["id1", {item1}, "id2", {item2}, ...]
+std::map<std::string, ArcSidebarItem> ParseItems(
+    const base::ListValue& items_list) {
+  std::map<std::string, ArcSidebarItem> items;
+
+  for (size_t i = 0; i + 1 < items_list.size(); i += 2) {
+    const auto* id_str = items_list[i].GetIfString();
+    const auto* dict = items_list[i + 1].GetIfDict();
+    if (!id_str || !dict) {
+      continue;
+    }
+
+    ArcSidebarItem item;
+    item.id = *id_str;
+
+    if (const auto* title = dict->FindString("title")) {
+      item.title = *title;
+    }
+
+    if (auto created = dict->FindDouble("createdAt")) {
+      item.created_at = *created;
+    }
+
+    if (const auto* children = dict->FindList("childrenIds")) {
+      for (const auto& child : *children) {
+        if (const auto* child_str = child.GetIfString()) {
+          item.children_ids.push_back(*child_str);
+        }
+      }
+    }
+
+    // Check if this is a tab (has URL) or a container.
+    const auto* data = dict->FindDict("data");
+    const auto* tab = data ? data->FindDict("tab") : nullptr;
+    const auto* container = data ? data->FindDict("itemContainer") : nullptr;
+
+    if (tab) {
+      if (const auto* url = tab->FindString("savedURL")) {
+        item.saved_url = *url;
+      }
+
+      if (const auto* title = tab->FindString("savedTitle")) {
+        item.saved_title = *title;
+      }
+    } else if (container) {
+      item.is_container = true;
+    }
+
+    items[item.id] = std::move(item);
+  }
+  return items;
+}
+
+void WalkItem(const std::string& item_id,
+              const std::map<std::string, ArcSidebarItem>& items,
+              const std::vector<std::u16string>& path,
+              bool in_toolbar,
+              std::vector<user_data_importer::ImportedBookmarkEntry>* bookmarks,
+              std::unordered_set<std::string>& visited) {
+  if (!visited.insert(item_id).second) {
+    return;
+  }
+
+  auto it = items.find(item_id);
+  if (it == items.end()) {
+    return;
+  }
+
+  const ArcSidebarItem& item = it->second;
+  if (item.saved_url.starts_with("arc://")) {
+    return;
+  }
+
+  bool is_folder = item.saved_url.empty() && !item.children_ids.empty() &&
+                   !item.is_container;
+
+  if (!item.saved_url.empty()) {
+    user_data_importer::ImportedBookmarkEntry entry;
+    entry.in_toolbar = in_toolbar;
+    entry.is_folder = false;
+    entry.url = GURL(item.saved_url);
+    entry.path = path;
+    entry.title =
+        base::UTF8ToUTF16(!item.title.empty() ? item.title : item.saved_title);
+    if (item.created_at > 0) {
+      entry.creation_time = CFAbsoluteTimeToBaseTime(item.created_at);
+    }
+    bookmarks->push_back(std::move(entry));
+  } else if (is_folder) {
+    std::string folder_name = item.title;
+    if (folder_name.empty()) {
+      folder_name = item.saved_title;
+    }
+    if (folder_name.empty()) {
+      folder_name = "Folder";
+    }
+
+    std::vector<std::u16string> child_path = path;
+    child_path.push_back(base::UTF8ToUTF16(folder_name));
+    for (const auto& child_id : item.children_ids) {
+      WalkItem(child_id, items, child_path, in_toolbar, bookmarks, visited);
+    }
+    return;
+  }
+
+  // For containers, just recurse into children.
+  if (item.is_container) {
+    for (const auto& child_id : item.children_ids) {
+      WalkItem(child_id, items, path, in_toolbar, bookmarks, visited);
+    }
+  }
+}
+
+struct SpaceInfo {
+  std::string id;
+  std::string pinned_container_id;
+};
+
+// Parse the spaces list from the sidebar data container.
+// Spaces alternate: ["spaceId", {spaceObj}, ...] and each space has
+// containerIDs: ["pinned", "<id>", "unpinned", "<id>"].
+std::vector<SpaceInfo> ParseSpaces(const base::ListValue* spaces_list) {
+  std::vector<SpaceInfo> spaces;
+  if (!spaces_list) {
+    return spaces;
+  }
+
+  for (size_t i = 0; i + 1 < spaces_list->size(); i += 2) {
+    const auto* space_id = (*spaces_list)[i].GetIfString();
+    const auto* space_dict = (*spaces_list)[i + 1].GetIfDict();
+    if (!space_id || !space_dict) {
+      continue;
+    }
+
+    SpaceInfo space;
+    space.id = *space_id;
+
+    const auto* container_ids = space_dict->FindList("containerIDs");
+    if (container_ids) {
+      for (size_t j = 0; j + 1 < container_ids->size(); j += 2) {
+        const auto* label = (*container_ids)[j].GetIfString();
+        const auto* cid = (*container_ids)[j + 1].GetIfString();
+        if (!label || !cid) {
+          continue;
+        }
+        if (*label == "pinned") {
+          space.pinned_container_id = *cid;
+        }
+      }
+    }
+
+    spaces.push_back(std::move(space));
+  }
+  return spaces;
+}
+
+}  // namespace
+
+ArcSidebarImporter::ArcSidebarImporter() = default;
+
+ArcSidebarImporter::~ArcSidebarImporter() = default;
+
+constexpr const base::FilePath::StringViewType kStorableSidebarFilename =
+    FILE_PATH_LITERAL("StorableSidebar.json");
+
+base::FilePath ArcSidebarImporter::GetStorableSidebarPath() const {
+  const std::array<base::FilePath, 3> sidebar_paths = {
+      source_path_.DirName().DirName().Append(kStorableSidebarFilename),
+      source_path_.DirName().Append(kStorableSidebarFilename),
+      source_path_.Append(kStorableSidebarFilename),
+  };
+
+  for (const auto& path : sidebar_paths) {
+    if (base::PathExists(path)) {
+      return path;
+    }
+  }
+
+  return {};
+}
+
+std::optional<base::DictValue> ArcSidebarImporter::LoadSidebarData(
+    base::FilePath path) const {
+  std::string sidebar_content;
+  if (!base::ReadFileToString(path, &sidebar_content)) {
+    LOG(WARNING) << "failed to read arc data";
+    return std::nullopt;
+  }
+
+  std::optional<base::DictValue> root = base::JSONReader::ReadDict(
+      sidebar_content, base::JSON_PARSE_CHROMIUM_EXTENSIONS);
+  if (!root) {
+    LOG(WARNING) << "failed to parse arc data";
+    return std::nullopt;
+  }
+
+  if (!root->FindDict("sidebar")) {
+    return std::nullopt;
+  }
+
+  return root;
+}
+
+void ArcSidebarImporter::ImportBookmarksImpl() {
+  base::FilePath path = GetStorableSidebarPath();
+  if (path.empty()) {
+    return;
+  }
+
+  auto root = LoadSidebarData(path);
+  if (!root) {
+    return;
+  }
+
+  const auto* sidebar = root->FindDict("sidebar");
+  const auto* containers = sidebar->FindList("containers");
+  if (!containers || containers->size() < 2) {
+    return;
+  }
+
+  const auto* data_container = (*containers)[1].GetIfDict();
+  if (!data_container) {
+    return;
+  }
+
+  const auto* items_list = data_container->FindList("items");
+  if (!items_list) {
+    return;
+  }
+
+  auto items = ParseItems(*items_list);
+  if (items.empty()) {
+    return;
+  }
+
+  auto spaces = ParseSpaces(data_container->FindList("spaces"));
+  std::unordered_set<std::string> visited_ids;
+  std::vector<user_data_importer::ImportedBookmarkEntry> bookmarks;
+  const auto* top_apps_ids = data_container->FindList("topAppsContainerIDs");
+  if (top_apps_ids) {
+    for (size_t i = 0; i + 1 < top_apps_ids->size(); i += 2) {
+      const auto* id = (*top_apps_ids)[i + 1].GetIfString();
+      if (!id) {
+        continue;
+      }
+      auto it = items.find(*id);
+      if (it != items.end()) {
+        std::vector<std::u16string> path_parts;
+        for (const auto& child_id : it->second.children_ids) {
+          WalkItem(child_id, items, path_parts, /*in_toolbar=*/true, &bookmarks,
+                   visited_ids);
+        }
+      }
+      break;
+    }
+  }
+
+  bool multiple_spaces = spaces.size() > 1;
+
+  for (const auto& space : spaces) {
+    if (space.pinned_container_id.empty()) {
+      continue;
+    }
+
+    auto it = items.find(space.pinned_container_id);
+    if (it == items.end() || it->second.children_ids.empty()) {
+      continue;
+    }
+
+    std::vector<std::u16string> path_parts;
+    if (multiple_spaces) {
+      std::string space_name = space.id;
+      if (space_name.contains("defaultPersonalSpaceID")) {
+        space_name = "Personal";
+      }
+      path_parts.push_back(base::UTF8ToUTF16(space_name));
+    }
+
+    for (const auto& child_id : it->second.children_ids) {
+      WalkItem(child_id, items, path_parts, /*in_toolbar=*/false, &bookmarks,
+               visited_ids);
+    }
+  }
+
+  if (!bookmarks.empty() && !cancelled()) {
+    bridge_->AddBookmarks(
+        bookmarks, l10n_util::GetStringFUTF16(IDS_IMPORTED_FROM_BOOKMARK_FOLDER,
+                                              importer_name_));
+  }
+}
+
+void ArcSidebarImporter::ImportBookmarks() {
+  // Only call the base class if the Chromium Bookmarks file exists — Arc
+  // typically doesn't have one, and ScopedCopyFile DCHECKs on missing files.
+  base::FilePath bookmarks_path = source_path_.Append(
+      base::FilePath::StringType(FILE_PATH_LITERAL("Bookmarks")));
+  if (base::PathExists(bookmarks_path)) {
+    ChromeImporter::ImportBookmarks();
+  }
+  ImportBookmarksImpl();
+}
