@@ -0,0 +1,315 @@
+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/importer/arc_tab_group_importer.h"
+
+#include <array>
+#include <map>
+#include <string>
+#include <unordered_set>
+#include <vector>
+
+#include "base/files/file_util.h"
+#include "base/json/json_reader.h"
+#include "base/logging.h"
+#include "base/strings/utf_string_conversions.h"
+#include "base/uuid.h"
+#include "base/values.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/tab_group_sync/tab_group_sync_service_factory.h"
+#include "chrome/browser/ui/browser.h"
+#include "chrome/browser/ui/browser_finder.h"
+#include "chrome/browser/ui/tabs/saved_tab_groups/tab_group_action_context_desktop.h"
+#include "components/saved_tab_groups/public/saved_tab_group.h"
+#include "components/saved_tab_groups/public/saved_tab_group_tab.h"
+#include "components/saved_tab_groups/public/tab_group_sync_service.h"
+#include "components/saved_tab_groups/public/types.h"
+#include "components/tab_groups/tab_group_color.h"
+#include "url/gurl.h"
+
+namespace arc_importer {
+
+namespace {
+
+constexpr double kCFAbsoluteTimeToUnixOffset = 978307200.0;
+
+struct ArcItem {
+  std::string id;
+  std::string title;
+  std::string saved_url;
+  std::string saved_title;
+  double created_at = 0;
+  std::vector<std::string> children_ids;
+  bool is_container = false;
+};
+
+std::map<std::string, ArcItem> ParseItems(const base::ListValue& items_list) {
+  std::map<std::string, ArcItem> items;
+  for (size_t i = 0; i + 1 < items_list.size(); i += 2) {
+    const auto* id_str = items_list[i].GetIfString();
+    const auto* dict = items_list[i + 1].GetIfDict();
+    if (!id_str || !dict) {
+      continue;
+    }
+
+    ArcItem item;
+    item.id = *id_str;
+
+    if (const auto* title = dict->FindString("title")) {
+      item.title = *title;
+    }
+    if (auto created = dict->FindDouble("createdAt")) {
+      item.created_at = *created;
+    }
+    if (const auto* children = dict->FindList("childrenIds")) {
+      for (const auto& child : *children) {
+        if (const auto* s = child.GetIfString()) {
+          item.children_ids.push_back(*s);
+        }
+      }
+    }
+
+    const auto* data = dict->FindDict("data");
+    const auto* tab = data ? data->FindDict("tab") : nullptr;
+    const auto* container = data ? data->FindDict("itemContainer") : nullptr;
+
+    if (tab) {
+      if (const auto* url = tab->FindString("savedURL")) {
+        item.saved_url = *url;
+      }
+      if (const auto* saved_title = tab->FindString("savedTitle")) {
+        item.saved_title = *saved_title;
+      }
+    } else if (container) {
+      item.is_container = true;
+    }
+
+    items[item.id] = std::move(item);
+  }
+  return items;
+}
+
+struct SpaceInfo {
+  std::string id;
+  std::string pinned_container_id;
+};
+
+std::vector<SpaceInfo> ParseSpaces(const base::ListValue* spaces_list) {
+  std::vector<SpaceInfo> spaces;
+  if (!spaces_list) {
+    return spaces;
+  }
+
+  for (size_t i = 0; i + 1 < spaces_list->size(); i += 2) {
+    const auto* space_id = (*spaces_list)[i].GetIfString();
+    const auto* space_dict = (*spaces_list)[i + 1].GetIfDict();
+    if (!space_id || !space_dict) {
+      continue;
+    }
+
+    SpaceInfo space;
+    space.id = *space_id;
+
+    const auto* container_ids = space_dict->FindList("containerIDs");
+    if (container_ids) {
+      for (size_t j = 0; j + 1 < container_ids->size(); j += 2) {
+        const auto* label = (*container_ids)[j].GetIfString();
+        const auto* cid = (*container_ids)[j + 1].GetIfString();
+        if (label && cid && *label == "pinned") {
+          space.pinned_container_id = *cid;
+        }
+      }
+    }
+
+    spaces.push_back(std::move(space));
+  }
+  return spaces;
+}
+
+void CollectTabs(
+    const std::string& item_id,
+    const std::map<std::string, ArcItem>& items,
+    std::unordered_set<std::string>& visited,
+    std::vector<tab_groups::SavedTabGroupTab>& tabs,
+    const base::Uuid& group_guid) {
+  if (!visited.insert(item_id).second) {
+    return;
+  }
+
+  auto it = items.find(item_id);
+  if (it == items.end()) {
+    return;
+  }
+
+  const ArcItem& item = it->second;
+  if (item.saved_url.starts_with("arc://")) {
+    return;
+  }
+
+  if (!item.saved_url.empty()) {
+    GURL url(item.saved_url);
+    if (url.is_valid()) {
+      std::u16string title = base::UTF8ToUTF16(
+          !item.title.empty() ? item.title : item.saved_title);
+      std::optional<base::Time> creation_time;
+      if (item.created_at > 0) {
+        creation_time = base::Time::FromSecondsSinceUnixEpoch(
+            item.created_at + kCFAbsoluteTimeToUnixOffset);
+      }
+      tabs.emplace_back(url, title, group_guid, /*position=*/tabs.size(),
+                        /*saved_tab_guid=*/std::nullopt,
+                        /*local_tab_id=*/std::nullopt,
+                        /*creator_cache_guid=*/std::nullopt,
+                        /*last_updater_cache_guid=*/std::nullopt,
+                        creation_time);
+    }
+  }
+
+  for (const auto& child_id : item.children_ids) {
+    CollectTabs(child_id, items, visited, tabs, group_guid);
+  }
+}
+
+tab_groups::TabGroupColorId ColorForIndex(size_t index) {
+  constexpr std::array<tab_groups::TabGroupColorId, 7> kColors = {
+      tab_groups::TabGroupColorId::kBlue,
+      tab_groups::TabGroupColorId::kRed,
+      tab_groups::TabGroupColorId::kYellow,
+      tab_groups::TabGroupColorId::kGreen,
+      tab_groups::TabGroupColorId::kPink,
+      tab_groups::TabGroupColorId::kPurple,
+      tab_groups::TabGroupColorId::kCyan,
+  };
+  return kColors[index % kColors.size()];
+}
+
+std::string SpaceDisplayName(const std::string& space_id) {
+  if (space_id.find("defaultPersonalSpaceID") != std::string::npos) {
+    return "Personal";
+  }
+  if (space_id.size() > 8) {
+    return "Space " + space_id.substr(space_id.size() - 8);
+  }
+  return space_id.empty() ? "Space" : space_id;
+}
+
+base::FilePath FindStorableSidebarPath(const base::FilePath& source_path) {
+  constexpr base::FilePath::StringViewType kFilename =
+      FILE_PATH_LITERAL("StorableSidebar.json");
+  const std::array<base::FilePath, 3> candidates = {
+      source_path.DirName().DirName().Append(kFilename),
+      source_path.DirName().Append(kFilename),
+      source_path.Append(kFilename),
+  };
+  for (const auto& p : candidates) {
+    if (base::PathExists(p)) {
+      return p;
+    }
+  }
+  return {};
+}
+
+}  // namespace
+
+void ImportArcSpacesAsTabGroups(Profile* profile,
+                                const base::FilePath& source_path) {
+  auto* service =
+      tab_groups::TabGroupSyncServiceFactory::GetForProfile(profile);
+  if (!service) {
+    LOG(WARNING) << "arc_tab_group_importer: TabGroupSyncService unavailable";
+    return;
+  }
+
+  Browser* browser = chrome::FindLastActive();
+  if (!browser) {
+    LOG(WARNING) << "arc_tab_group_importer: no active browser";
+    return;
+  }
+
+  base::FilePath sidebar_path = FindStorableSidebarPath(source_path);
+  if (sidebar_path.empty()) {
+    return;
+  }
+
+  std::string content;
+  if (!base::ReadFileToString(sidebar_path, &content)) {
+    LOG(WARNING) << "arc_tab_group_importer: failed to read StorableSidebar";
+    return;
+  }
+
+  std::optional<base::DictValue> root =
+      base::JSONReader::ReadDict(content, base::JSON_PARSE_CHROMIUM_EXTENSIONS);
+  if (!root) {
+    LOG(WARNING) << "arc_tab_group_importer: failed to parse JSON";
+    return;
+  }
+
+  const auto* sidebar = root->FindDict("sidebar");
+  if (!sidebar) {
+    return;
+  }
+  const auto* containers = sidebar->FindList("containers");
+  if (!containers || containers->size() < 2) {
+    return;
+  }
+  const auto* data_container = (*containers)[1].GetIfDict();
+  if (!data_container) {
+    return;
+  }
+
+  const auto* items_list = data_container->FindList("items");
+  if (!items_list) {
+    return;
+  }
+
+  auto items = ParseItems(*items_list);
+  if (items.empty()) {
+    return;
+  }
+
+  auto spaces = ParseSpaces(data_container->FindList("spaces"));
+  if (spaces.empty()) {
+    return;
+  }
+
+  size_t color_index = 0;
+  for (const auto& space : spaces) {
+    if (space.pinned_container_id.empty()) {
+      continue;
+    }
+
+    auto it = items.find(space.pinned_container_id);
+    if (it == items.end() || it->second.children_ids.empty()) {
+      continue;
+    }
+
+    base::Uuid group_guid = base::Uuid::GenerateRandomV4();
+    std::vector<tab_groups::SavedTabGroupTab> tabs;
+    std::unordered_set<std::string> visited;
+
+    for (const auto& child_id : it->second.children_ids) {
+      CollectTabs(child_id, items, visited, tabs, group_guid);
+    }
+
+    if (tabs.empty()) {
+      continue;
+    }
+
+    std::u16string group_title =
+        base::UTF8ToUTF16(SpaceDisplayName(space.id));
+    tab_groups::SavedTabGroup group(group_title, ColorForIndex(color_index++),
+                                   tabs,
+                                   /*position=*/std::nullopt, group_guid);
+    service->AddGroup(std::move(group));
+
+    // Open the group immediately so it appears in the tab strip with
+    // hibernated tabs rather than waiting for the next restart.
+    service->OpenTabGroup(
+        group_guid,
+        std::make_unique<tab_groups::TabGroupActionContextDesktop>(
+            browser, tab_groups::OpeningSource::kUnknown));
+  }
+}
+
+}  // namespace arc_importer
