+
+#include "base/files/file_path.h"
+
+class Profile;
+
+namespace arc_importer {
+
+// Parses StorableSidebar.json from the Arc source path and creates a
+// SavedTabGroup for each Arc space that has pinned tabs. Must be called on
+// the UI thread with a valid Profile*.
+void ImportArcSpacesAsTabGroups(Profile* profile,
+                                const base::FilePath& source_path);
