 void TabGroupSyncDelegateDesktop::OnInitialized() {
   StartRecordingHourlyMetrics();
+
+  // Air: defer group restoration so it runs after the current observer
+  // iteration (ProfileObserver with kDisallowReentrancy) unwinds.
+  base::SequencedTaskRunner::GetCurrentDefault()->PostTask(
+      FROM_HERE,
+      base::BindOnce(&TabGroupSyncDelegateDesktop::RestoreSavedTabGroups,
+                     weak_ptr_factory_.GetWeakPtr()));
+}
+
+void TabGroupSyncDelegateDesktop::RestoreSavedTabGroups() {
+  Browser* browser = nullptr;
+  ForEachCurrentBrowserWindowInterfaceOrderedByActivation(
+      [this, &browser](BrowserWindowInterface* bwi) -> bool {
+        if (bwi->GetProfile() == profile_) {
+          browser = bwi->GetBrowserForMigrationOnly();
+          return false;
+        }
+        return true;
+      });
+  if (!browser) return;
+
+  for (const SavedTabGroup* group : service_->ReadAllGroups()) {
+    if (!group || group->local_group_id().has_value()) continue;
+    if (group->saved_tabs().empty()) continue;
+
+    std::map<tabs::TabInterface*, base::Uuid> tab_guid_mapping =
+        OpenTabsAndMapToUuids(browser, *group);
+    if (!tab_guid_mapping.empty()) {
+      AddOpenedTabsToGroup(browser->tab_strip_model(),
+                           std::move(tab_guid_mapping), *group,
+                           /*switch_focus=*/false);
+    }
+  }
 }
 
