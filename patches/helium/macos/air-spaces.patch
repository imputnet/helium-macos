+#ifndef CHROME_BROWSER_UI_TABS_AIR_SPACES_MANAGER_H_
+#define CHROME_BROWSER_UI_TABS_AIR_SPACES_MANAGER_H_
+
+#include <map>
+#include <optional>
+#include <string>
+#include <vector>
+
+#include "base/memory/raw_ptr.h"
+#include "base/observer_list.h"
+#include "components/keyed_service/core/keyed_service.h"
+#include "components/tab_groups/tab_group_color.h"
+#include "components/tab_groups/tab_group_id.h"
+
+class Profile;
+class TabStripModel;
+
+namespace air {
+
+struct Space {
+  std::string id;
+  std::u16string name;
+  tab_groups::TabGroupColorId color;
+  std::string icon;
+};
+
+class AirSpacesManagerObserver {
+ public:
+  virtual void OnSpaceCreated(const Space& space) {}
+  virtual void OnSpaceDeleted(const std::string& space_id) {}
+  virtual void OnSpaceRenamed(const std::string& space_id,
+                               const std::u16string& new_name) {}
+  virtual void OnActiveSpaceChanged(const std::string& space_id) {}
+};
+
+class AirSpacesManager : public KeyedService {
+ public:
+  explicit AirSpacesManager(Profile* profile);
+  ~AirSpacesManager() override;
+
+  AirSpacesManager(const AirSpacesManager&) = delete;
+  AirSpacesManager& operator=(const AirSpacesManager&) = delete;
+
+  const std::vector<Space>& GetSpaces() const { return spaces_; }
+  const std::string& GetActiveSpaceId() const { return active_space_id_; }
+
+  Space CreateSpace(const std::u16string& name,
+                    tab_groups::TabGroupColorId color,
+                    const std::string& icon = "");
+  void SwitchToSpace(const std::string& space_id, TabStripModel* tab_strip);
+  void RenameSpace(const std::string& space_id, const std::u16string& new_name);
+  void DeleteSpace(const std::string& space_id, TabStripModel* tab_strip);
+
+  std::optional<tab_groups::TabGroupId> GetTabGroupForSpace(
+      const std::string& space_id) const;
+
+  void AddObserver(AirSpacesManagerObserver* observer);
+  void RemoveObserver(AirSpacesManagerObserver* observer);
+
+ private:
+  void LoadFromPrefs();
+  void SaveToPrefs();
+  std::string GenerateSpaceId();
+
+  raw_ptr<Profile> profile_;
+  std::vector<Space> spaces_;
+  std::string active_space_id_;
+  std::map<std::string, tab_groups::TabGroupId> space_to_group_;
+  base::ObserverList<AirSpacesManagerObserver> observers_;
+};
+
+}  // namespace air
+
+#endif  // CHROME_BROWSER_UI_TABS_AIR_SPACES_MANAGER_H_
