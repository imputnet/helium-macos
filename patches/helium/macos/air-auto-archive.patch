+#ifndef CHROME_BROWSER_UI_TABS_AIR_TAB_ARCHIVE_SERVICE_H_
+#define CHROME_BROWSER_UI_TABS_AIR_TAB_ARCHIVE_SERVICE_H_
+
+#include <map>
+#include <string>
+#include <vector>
+
+#include "base/memory/raw_ptr.h"
+#include "base/observer_list.h"
+#include "base/time/time.h"
+#include "base/timer/timer.h"
+#include "chrome/browser/ui/tabs/tab_strip_model_observer.h"
+#include "components/keyed_service/core/keyed_service.h"
+#include "url/gurl.h"
+
+class Profile;
+class TabStripModel;
+
+namespace air {
+
+struct ArchivedTab {
+  GURL url;
+  std::u16string title;
+  base::Time archived_at;
+};
+
+class AirTabArchiveObserver {
+ public:
+  virtual void OnTabArchived(const ArchivedTab& tab) {}
+  virtual void OnArchivedTabRestored(const GURL& url) {}
+  virtual void OnArchiveCleared() {}
+};
+
+class AirTabArchiveService : public KeyedService,
+                              public TabStripModelObserver {
+ public:
+  enum class ArchiveThreshold {
+    kNever = 0,
+    kOneDay = 1,
+    kThreeDays = 3,
+    kOneWeek = 7,
+  };
+
+  explicit AirTabArchiveService(Profile* profile);
+  ~AirTabArchiveService() override;
+
+  AirTabArchiveService(const AirTabArchiveService&) = delete;
+  AirTabArchiveService& operator=(const AirTabArchiveService&) = delete;
+
+  void ObserveTabStrip(TabStripModel* tab_strip);
+
+  const std::vector<ArchivedTab>& GetArchivedTabs() const {
+    return archived_tabs_;
+  }
+
+  ArchiveThreshold GetThreshold() const { return threshold_; }
+  void SetThreshold(ArchiveThreshold threshold);
+
+  void RestoreTab(const GURL& url, TabStripModel* tab_strip);
+  void ClearArchive();
+
+  void AddObserver(AirTabArchiveObserver* observer);
+  void RemoveObserver(AirTabArchiveObserver* observer);
+
+ private:
+  void OnTabStripModelChanged(
+      TabStripModel* tab_strip_model,
+      const TabStripModelChange& change,
+      const TabStripSelectionChange& selection) override;
+
+  void OnHourlyCheck();
+  void LoadFromPrefs();
+  void SaveToPrefs();
+  base::TimeDelta ThresholdDelta() const;
+
+  raw_ptr<Profile> profile_;
+  raw_ptr<TabStripModel> observed_tab_strip_ = nullptr;
+  std::vector<ArchivedTab> archived_tabs_;
+  ArchiveThreshold threshold_ = ArchiveThreshold::kOneDay;
+  std::map<int, base::Time> tab_last_activated_;
+  base::RepeatingTimer hourly_timer_;
+  base::ObserverList<AirTabArchiveObserver> observers_;
+};
+
+}  // namespace air
+
+#endif  // CHROME_BROWSER_UI_TABS_AIR_TAB_ARCHIVE_SERVICE_H_
